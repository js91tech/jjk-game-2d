# Same Discord application as jjkbot bot
VITE_DISCORD_CLIENT_ID=1506793287963512832

# jjkbot API (local or Railway)
VITE_API_URL=http://localhost:3848

# Local dev without Discord iframe — must match ALLOW_DEV_AUTH on API
# Or launch from web dashboard /play/2d (passes ?discord_id= in URL)
VITE_DEV_DISCORD_ID=your_discord_user_id
VITE_DEV_USERNAME=YourName
