# Same Discord application as jjkbot bot
VITE_DISCORD_CLIENT_ID=your_application_id

# jjkbot API (local dev only — NOT used inside Discord Activity; Activity uses /api proxy)
VITE_API_URL=http://localhost:3848

# LOCAL DEV ONLY — do NOT set on Railway production build (causes "Unauthorized" in Activity)
# VITE_DEV_DISCORD_ID=your_discord_user_id
# VITE_DEV_USERNAME=YourName
